# Copy this file to .env — never commit .env to git.

# ── Anthropic Admin API key (REQUIRED for live data fetching) ─────────────
# Get one at: console.anthropic.com/settings/admin-keys
# Must be org admin. Starts with sk-ant-admin-...
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# ── Anthropic API key (REQUIRED for CSV column detection on upload) ────────
# Get one at: console.anthropic.com/settings/api-keys
# Starts with sk-ant-...  Used by the upload endpoint to map CSV columns.
ANTHROPIC_API_KEY=sk-ant-...

# ── API server port (default 3001) ─────────────────────────────────────────
# PORT=3001
